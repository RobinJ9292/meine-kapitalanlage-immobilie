Options -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # www -> non-www (Canonical-Host, verhindert Duplicate Content)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # Alte Pfade dauerhaft auf neue umleiten (Linkkraft/SEO erhalten, alte Lesezeichen funktionieren)
  RewriteRule ^lexikon/(.*)$ /ratgeber/$1 [R=301,L]
  RewriteRule ^lexikon/?$ /ratgeber/ [R=301,L]
  RewriteRule ^einordnung/(.*)$ /aktuelles/$1 [R=301,L]
  RewriteRule ^einordnung/?$ /aktuelles/ [R=301,L]

  # Landingpage unter /beratung ausliefern (Datei bleibt an der Wurzel: beratung.html,
  # damit die relativen Asset-Pfade der LP unveraendert funktionieren)
  RewriteRule ^beratung/$ /beratung [R=301,L]
  RewriteRule ^beratung$ beratung.html [L]
</IfModule>

# leichte Caching-Header fuer statische Assets
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML nur kurz cachen -> Aenderungen werden nach Push/Deploy zeitnah live
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
</IfModule>

# HTML explizit kurz halten und revalidieren lassen (Browser + kooperierende CDNs)
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>
